{
  "manifest_version": 3,
  "name": "1-800-CLOSER Audio Bridge",
  "version": "1.0.0",
  "description": "Captures Google Meet tab audio for manager listen-in via the 1-800-CLOSER platform.",
  "permissions": [
    "tabCapture",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "externally_connectable": {
    "matches": ["http://localhost:*/*", "https://*.vercel.app/*", "https://*.netlify.app/*"]
  }
}
